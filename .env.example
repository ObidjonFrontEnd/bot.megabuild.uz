# ==========================================================================
#  НАСТРОЙКИ БОТА
#  Скопируйте этот файл в .env и заполните значения ниже.
#  Команда: cp .env.example .env   (установщик install.sh сделает это сам)
# ==========================================================================

# --- ОБЯЗАТЕЛЬНО ЗАПОЛНИТЬ ---

# 1) Токен Telegram-бота. Получить у @BotFather.
TELEGRAM_TOKEN=

# 2) Адрес API основного сервера (Yii2). БЕЗ слэша в конце.
#    Пример: http://46.62.246.156/api   или   https://ваш-домен.uz/api
YII2_API_BASE_URL=

# 3) Публичный адрес самого бота (https). Нужен для Telegram webhook и Mini App.
#    Пример: https://bot.ваш-домен.uz
APP_URL=

# --- ОБЫЧНО МЕНЯТЬ НЕ НУЖНО ---

# Общий секрет между Yii2 и ботом (заголовок X-Secret-Token).
# Должен совпадать с тем, что настроен на основном сервере.
YII2_INCOMING_SECRET=shared_secret_between_yii2_and_bot

# Секрет для проверки входящих запросов от Telegram (можно оставить пустым).
TELEGRAM_WEBHOOK_SECRET=

# Путь к базе бота (SQLite). Оставьте ПУСТЫМ —
# база сама создастся в папке data/ внутри проекта.
DB_PATH=
